{
  "$schema": "https://schemas.tokens.studio/latest/tokens-schema.json",
  "_meta": {
    "name": "Darwoft Design System",
    "version": "2.0.0",
    "source": "https://www.darwoft.com (live computed styles, Framer Darwoft-Site-2025)",
    "description": "Design tokens extracted from the real Darwoft website. Dark-first brand. Tokens Studio / W3C compatible — import into Figma via the Tokens Studio plugin."
  },
  "color": {
    "brand": {
      "blue":  { "$type": "color", "$value": "#118DF0", "$description": "Primary interactive / electric blue. Used on links, key CTAs, focus." },
