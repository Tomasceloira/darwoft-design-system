      "lime":  { "$type": "color", "$value": "#E5F33C", "$description": "Signature lime accent. Decorative + highlight words." },
      "steel": { "$type": "color", "$value": "#455A6F", "$description": "Muted steel-blue. Overlines and subdued labels." }
    },
    "neutral": {
      "white":  { "$type": "color", "$value": "#FFFFFF" },
      "fg":     { "$type": "color", "$value": "#F2F2F2", "$description": "Primary text on dark." },
      "muted":  { "$type": "color", "$value": "#727279", "$description": "Secondary / muted text." },
      "ink-700":{ "$type": "color", "$value": "#3B3B3B", "$description": "Chips, strong borders." },
      "ink-800":{ "$type": "color", "$value": "#232325", "$description": "Popover / elevated surface." },
      "ink-850":{ "$type": "color", "$value": "#1C1C1E", "$description": "Card surface (dark)." },
      "ink-900":{ "$type": "color", "$value": "#151515", "$description": "Body background (dark)." },
      "ink-950":{ "$type": "color", "$value": "#101111", "$description": "Deepest background / sections." },
      "hairline":       { "$type": "color", "$value": "rgba(255,255,255,0.10)", "$description": "Subtle border on dark." },
      "hairline-strong":{ "$type": "color", "$value": "rgba(255,255,255,0.15)", "$description": "Card ring border on dark." }
    },
    "light": {
