  "font": {
    "family": {
      "display": { "$type": "fontFamily", "$value": "Fraunces, Georgia, 'Times New Roman', serif", "$description": "Editorial serif for headings (real site font)." },
      "sans":    { "$type": "fontFamily", "$value": "Inter, system-ui, -apple-system, sans-serif", "$description": "UI + body + large statement text." }
    },
    "weight": {
      "light":    { "$type": "fontWeight", "$value": 300 },
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold":     { "$type": "fontWeight", "$value": 700 }
    },
    "size": {
      "xs":      { "$type": "dimension", "$value": "12px" },
      "sm":      { "$type": "dimension", "$value": "14px" },
      "base":    { "$type": "dimension", "$value": "16px" },
      "lg":      { "$type": "dimension", "$value": "18px" },
      "xl":      { "$type": "dimension", "$value": "24px" },
      "2xl":     { "$type": "dimension", "$value": "32px" },
      "3xl":     { "$type": "dimension", "$value": "40px" },
      "4xl":     { "$type": "dimension", "$value": "56px" },
      "5xl":     { "$type": "dimension", "$value": "72px" },
      "6xl":     { "$type": "dimension", "$value": "88px" },
      "display": { "$type": "dimension", "$value": "120px" }
    },
    "lineHeight": {
      "tight":   { "$type": "number", "$value": 1.05 },
      "snug":    { "$type": "number", "$value": 1.2 },
      "normal":  { "$type": "number", "$value": 1.5 },
      "relaxed": { "$type": "number", "$value": 1.65 }
    },
    "letterSpacing": {
      "tight":    { "$type": "dimension", "$value": "-0.02em" },
      "display":  { "$type": "dimension", "$value": "0.5px" },
      "normal":   { "$type": "dimension", "$value": "0em" },
      "overline": { "$type": "dimension", "$value": "0.1em" }
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0px" },
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "20px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" },
    "10":{ "$type": "dimension", "$value": "40px" },
    "12":{ "$type": "dimension", "$value": "48px" },
    "16":{ "$type": "dimension", "$value": "64px" },
    "20":{ "$type": "dimension", "$value": "80px" },
    "24":{ "$type": "dimension", "$value": "96px" },
    "30":{ "$type": "dimension", "$value": "120px" }
  },
  "radius": {
    "sm":   { "$type": "dimension", "$value": "4px" },
    "md":   { "$type": "dimension", "$value": "8px" },
    "lg":   { "$type": "dimension", "$value": "12px" },
    "xl":   { "$type": "dimension", "$value": "16px", "$description": "Signature card radius on darwoft.com." },
    "pill": { "$type": "dimension", "$value": "9999px", "$description": "Buttons, chips, badges." }
  },
  "shadow": {
    "ring":  { "$type": "shadow", "$value": "0 0 0 1px rgba(255,255,255,0.15)", "$description": "Dark-surface card ring." },
    "sm":    { "$type": "shadow", "$value": "0 2px 4px 0 rgba(0,0,0,0.10), 0 1px 0 0 rgba(0,0,0,0.05)" },
    "md":    { "$type": "shadow", "$value": "0 8px 24px -6px rgba(0,0,0,0.40)" },
    "lg":    { "$type": "shadow", "$value": "0 20px 48px -12px rgba(0,0,0,0.55)" },
    "glow":  { "$type": "shadow", "$value": "0 -10px 40px 0 rgba(0,0,0,0.70)" }
  },
  "motion": {
    "duration": {
      "fast":      { "$type": "duration", "$value": "150ms" },
      "default":   { "$type": "duration", "$value": "250ms" },
      "slow":      { "$type": "duration", "$value": "400ms" },
      "cinematic": { "$type": "duration", "$value": "600ms" }
    },
    "easing": {
      "out":    { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] },
      "inOut":  { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] },
      "spring": { "$type": "cubicBezier", "$value": [0.34, 1.56, 0.64, 1] }
    }
  },
  "breakpoint": {
    "sm": { "$type": "dimension", "$value": "640px" },
    "md": { "$type": "dimension", "$value": "768px" },
    "lg": { "$type": "dimension", "$value": "1024px" },
    "xl": { "$type": "dimension", "$value": "1280px" },
    "2xl":{ "$type": "dimension", "$value": "1536px" }
